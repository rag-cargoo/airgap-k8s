apiVersion: metallb.io/v1beta1
kind: IPAddressPool
metadata:
  name: airgap-lb-pool
  namespace: metallb-system
spec:
  addresses:
    - __METALLB_ADDRESS_POOL__
---
apiVersion: metallb.io/v1beta1
kind: L2Advertisement
metadata:
  name: airgap-l2
  namespace: metallb-system
spec:
  ipAddressPools:
    - airgap-lb-pool
